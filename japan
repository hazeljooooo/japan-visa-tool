<script>
// ── 内嵌数据 ──
const PDF_B64  = "";
const FONT_B64 = "";

function v(id){const e=document.getElementById(id);return e?e.value.trim():'';}
function rv(name){const c=document.querySelector('input[name="'+name+'"]:checked');return c?c.value:'';}
function fd(s){if(!s)return'';const p=s.split('-');return p.length===3?p[2]+'/'+p[1]+'/'+p[0]:s;}
function hasCJK(s){return /[\u4e00-\u9fff\u3040-\u30ff]/.test(s);}

let cur=1;
const labels=['','基本信息','护照信息','行程信息','联系担保','确认导出'];
function go(n){
  if(n<1||n>5)return;
  document.getElementById('s'+cur).classList.remove('active');
  cur=n;
  document.getElementById('s'+cur).classList.add('active');
  for(let i=1;i<=5;i++){
    document.getElementById('d'+i).className='dot '+(i<cur?'done':i===cur?'active':'idle');
    if(i<5)document.getElementById('l'+i).className='ln '+(i<cur?'done':'idle');
  }
  document.getElementById('slbl').textContent=labels[cur];
  if(cur===5)buildSummary();
  window.scrollTo({top:0,behavior:'smooth'});
}
function next(){go(cur+1);}function prev(){go(cur-1);}

function buildSummary(){
  const rows=[
    ['姓名(英)',v('surname_en')+' '+v('given_en')],
    ['姓名(中)',v('surname_cn')+v('given_cn')],
    ['出生日期',fd(v('dob'))],['国籍',v('nationality')],
    ['护照号',v('passport_num')],['有效期',fd(v('expiry_date'))],
    ['赴日目的',v('purpose')],['抵达',fd(v('arrival_date'))],
    ['离开',fd(v('departure_date'))],['在日住址',v('hotel_name')],
    ['家庭电话',v('home_phone')],['单位名称',v('employer_name')],
  ].filter(([,val])=>val);
  document.getElementById('sumgrid').innerHTML=rows.map(([k,val])=>
    `<div class="sumrow"><span class="sumlbl">${k}:</span><span class="sumval">${val}</span></div>`).join('');
}

async function generate(){
  if(typeof PDFLib==='undefined'||typeof fontkit==='undefined'){
    alert('PDF库尚未加载完成，请稍等几秒后重试');return;
  }
  document.getElementById('ov').classList.add('show');
  document.getElementById('ov-msg').textContent='正在生成PDF…';
  document.getElementById('dl-btn').disabled=true;
  try{
    const {PDFDocument,rgb,StandardFonts}=PDFLib;
    const black=rgb(0,0,0);
    const PH=841.9;

    // Decode font (内嵌中文字体，无需网络)
    const fontBin=atob(FONT_B64);
    const fontBytes=new Uint8Array(fontBin.length);
    for(let i=0;i<fontBin.length;i++)fontBytes[i]=fontBin.charCodeAt(i);

    // Decode PDF
    const pdfBin=atob(PDF_B64);
    const pdfBytes=new Uint8Array(pdfBin.length);
    for(let i=0;i<pdfBin.length;i++)pdfBytes[i]=pdfBin.charCodeAt(i);

    const doc=await PDFDocument.load(pdfBytes.buffer);
    doc.registerFontkit(fontkit);

    // Embed fonts
    const cjkFont   = await doc.embedFont(fontBytes);   // NotoSansSC subset — supports CJK
    const latinFont = await doc.embedFont(StandardFonts.Helvetica);
    const latinBold = await doc.embedFont(StandardFonts.HelveticaBold);

    const pages=doc.getPages();
    const p1=pages[0],p2=pages[1];

    // Draw text: auto-selects CJK or Latin font
    // Accurately estimates pixel width for mixed CJK+Latin strings
    function estimateWidth(text, sz, isCJKFont){
      let w=0;
      for(let i=0;i<text.length;i++){
        const c=text.charCodeAt(i);
        const isCJKChar=(c>=0x4e00&&c<=0x9fff)||(c>=0x3040&&c<=0x30ff)||(c>=0xff00&&c<=0xffef);
        w += isCJKChar ? sz*1.05 : sz*0.62;
      }
      return w;
    }
    function dt(page,text,x,y,maxW,fs){
      if(!text)return;
      const t=String(text).trim();if(!t)return;
      const isCJK=hasCJK(t);
      const font=isCJK?cjkFont:latinFont;
      const sz=fs||(isCJK?7.5:8);
      // Trim to fit maxW using per-character width estimation
      let out=t;
      if(maxW){
        let acc=0,cutAt=t.length;
        for(let i=0;i<t.length;i++){
          const c=t.charCodeAt(i);
          const isCJKChar=(c>=0x4e00&&c<=0x9fff)||(c>=0x3040&&c<=0x30ff)||(c>=0xff00&&c<=0xffef);
          acc += isCJKChar ? sz*1.05 : sz*0.62;
          if(acc>maxW){cutAt=i;break;}
        }
        out=t.slice(0,cutAt);
      }
      page.drawText(out,{x,y,size:sz,font,color:black});
    }

    // Draw checkbox X
    function dcb(page,checked,x,y){
      if(!checked)return;
      page.drawText('X',{x,y,size:7,font:latinBold,color:black});
    }

    // ══ PAGE 1 ══
    // 姓: English field x0=185.9 line_top=231.8 → y=614
    dt(p1,v('surname_en').toUpperCase(), 190,614,218,8);
    // 姓: Chinese field x0=446.0 line_top=231.8 → y=614
    dt(p1,v('surname_cn'),               450,614,108,7.5);
    // 名: English x0=185.9 line_top=249.8 → y=596
    dt(p1,v('given_en').toUpperCase(),   190,596,218,8);
    // 名: Chinese x0=446.0 line_top=249.8 → y=596
    dt(p1,v('given_cn'),                 450,596,108,7.5);
    // 曾用名: English x0=163.9 line_top=269.8 → y=576
    dt(p1,v('alias_en').toUpperCase(),   168,576,240,8);
    // 曾用名: Chinese x0=446.0 line_top=269.8 → y=576
    dt(p1,v('alias_cn'),                 450,576,108,7.5);

    // 出生日期: x0=108.9 line_top=293.4 → y=552
    dt(p1,fd(v('dob')),                  113,552, 91,8);
    // 出生省: x0=248.6 line_top=293.4 → y=552
    dt(p1,v('birthplace_province'),      253,552, 95,7.5);
    // 出生市: after 省 label (省 label ends ~375) → x=390
    dt(p1,v('birthplace_city'),          394,552, 95,7.5);

    // 性别 checkboxes — exact rect positions from PDF rects:
    // 男□ rect x0=116.9, y0=302.9 → pdflib x=118, y=841.9-302.9-8=531.0
    // 女□ rect x0=163.4, y0=302.5 → pdflib x=164, y=531.4
    const sex=rv('sex');
    dcb(p1,sex==='male',   118,531);
    dcb(p1,sex==='female', 164,531);

    // 婚姻状况 checkboxes — exact rect positions:
    // 单身□ x0=330.9 y0=302.9  已婚□ x0=391.6  离婚□ x0=452.3  丧偶□ x0=513.0
    const mar=rv('marital');
    dcb(p1,mar==='single',  331,531);
    dcb(p1,mar==='married', 392,531);
    dcb(p1,mar==='divorced',453,531);
    dcb(p1,mar==='widowed', 513,531);

    // 国籍: x0=152.9 line_top=332.8 → y=513
    dt(p1,v('nationality'),              157,513,396,7.5);
    // 曾有国籍: x0=258.3 line_top=352.7 → y=493
    dt(p1,v('other_nationality'),        262,493,291,7.5);
    // 身份证: x0=119.9 line_top=372.6 → y=473
    dt(p1,v('id_number'),                124,473,429,8);

    // 护照类别 checkboxes — exact rect positions:
    // 外交□ x0=149.1 y0=382.5  公务□ x0=203.4  普通□ x0=257.7  其它□ x0=310.3
    // → pdflib y = 841.9-382.5-8 = 451.4
    const pt=rv('passtype');
    dcb(p1,pt==='diplomatic',150,451);
    dcb(p1,pt==='official',  204,451);
    dcb(p1,pt==='ordinary',  258,451);
    dcb(p1,pt==='other',     311,451);

    // 护照号码: x0=376.9 line_top=393.6 → y=452
    dt(p1,v('passport_num').toUpperCase(),381,452,168,8);
    // 签发地点: x0=108.9 line_top=414.9 → y=431
    dt(p1,v('issue_place'),              113,431,287,7.5);
    // 签发日期: x0=456.1 line_top=414.9 → y=431
    dt(p1,fd(v('issue_date')),           460,431, 93,8);
    // 签发机关: x0=108.9 line_top=434.8 → y=411
    dt(p1,v('issue_authority'),          113,411,287,7.5);
    // 有效日期: x0=456.1 line_top=434.7 → y=411
    dt(p1,fd(v('expiry_date')),          460,411, 93,8);
    // 在留认定证书编号: x0=189.2 line_top=457.9 → y=388
    dt(p1,v('coe_number'),               193,388, 96,8);
    // 赴日目的: x0=156.7 line_top=478.5 → y=367
    dt(p1,v('purpose'),                  161,367,399,7.5);
    // 抵达日期: x0=151.0 line_top=498.9 → y=347
    dt(p1,fd(v('arrival_date')),         155,347, 94,8);
    // 离开日期: x0=258.4 line_top=498.8 → y=347
    dt(p1,fd(v('departure_date')),       262,347,115,8);
    // 逗留天数: x0=462.4 line_top=498.5 → y=347
    dt(p1,v('stay_days'),                466,347, 93,7.5);
    // 入境口岸: x0=108.1 line_top=517.7 → y=328
    dt(p1,v('entry_port'),               112,328,181,7.5);
    // 航空公司: x0=405.0 line_top=517.7 → y=328
    dt(p1,v('carrier'),                  409,328,143,7.5);
    // 酒店名称: x0=191.5 line_top=556.1 → y=290
    dt(p1,v('hotel_name'),               196,290,211,7.5);
    // 酒店电话: x0=440.4 line_top=556.1 → y=290
    dt(p1,v('hotel_phone'),              444,290,108,8);
    // 在日地址: x0=114.5 line_top=587.4 → y=258
    dt(p1,v('hotel_address'),            119,258,433,7.5);
    // 上次赴日: x0=185.1 line_top=606.6 → y=239
    dt(p1,v('last_visit'),               189,239,363,7.5);
    // 家庭地址: x0=114.5 line_top=657.1 → y=189
    dt(p1,v('home_address'),             119,189,433,7.5);
    // 电话: x0=114.5 line_top=676.4 → y=169
    dt(p1,v('home_phone'),               119,169, 99,8);
    // 手机: x0=243.8 line_top=676.3 → y=169
    dt(p1,v('home_mobile'),              248,169, 99,8);
    // 电邮: x0=115.0 line_top=694.4 → y=151
    dt(p1,v('home_email'),               119,151,433,8);
    // 单位名称: x0=114.5 line_top=732.8 → y=113
    dt(p1,v('employer_name'),            119,113,289,7.5);
    // 单位电话: x0=440.4 line_top=732.8 → y=113
    dt(p1,v('employer_phone'),           444,113,108,8);
    // 单位地址: x0=114.5 line_top=764.2 → y=81
    dt(p1,v('employer_address'),         119, 81,433,7.5);
    // 职位: x0=119.1 line_top=783.3 → y=62
    dt(p1,v('job_title'),                123, 62,429,7.5);


    // ══ PAGE 2 ══
    // 配偶职业: x0=64.9 line_top=63.3 → y=782
    dt(p2,v('spouse_occupation'),         69,782,484,7.5);
    // 担保人姓名(英): x0=126.3 line_top=101.1 → y=745
    dt(p2,v('guarantor_name_en').toUpperCase(),130,745,278,8);
    // 担保人电话: x0=441.2 line_top=118.3 → y=727
    dt(p2,v('guarantor_phone'),           445,727,108,8);
    // 担保人地址: x0=126.3 line_top=149.4 → y=696
    dt(p2,v('guarantor_address'),         130,696,423,7.5);
    // 担保人出生日期: x0=137.3 line_top=200.1 → y=645
    dt(p2,fd(v('guarantor_dob')),         141,645, 91,8);
    // 担保人性别: 男□ x≈313 女□ x≈349, y=841.9-189.2-8=644
    const gsex=rv('guarantor_sex');
    dcb(p2,gsex==='male',  313,644);
    dcb(p2,gsex==='female',349,644);
    // 担保人关系: x0=170.3 line_top=219.0 → y=626
    dt(p2,v('guarantor_relation'),        174,626,379,7.5);
    // 担保人职业: x0=148.3 line_top=237.9 → y=607
    dt(p2,v('guarantor_job'),             152,607,401,7.5);
    // 担保人国籍: x0=236.3 line_top=256.8 → y=589
    dt(p2,v('guarantor_nationality'),     240,589,313,7.5);

    // 邀请人姓名: x0=118.4 line_top=299.7 → y=546
    dt(p2,v('inviter_name'),              122,546,289,7.5);
    // 邀请人电话: x0=444.3 line_top=299.7 → y=546
    dt(p2,v('inviter_phone'),             448,546,108,8);
    // 邀请人地址: x0=118.4 line_top=330.8 → y=515
    dt(p2,v('inviter_address'),           122,515,434,7.5);
    // 邀请人出生日期: x0=140.4 line_top=349.7 → y=496
    dt(p2,fd(v('inviter_dob')),           144,496, 91,8);
    // 邀请人性别: y=841.9-338.9-8=495
    const isex=rv('inviter_sex');
    dcb(p2,isex==='male',  313,495);
    dcb(p2,isex==='female',349,495);
    // 邀请人关系: x0=173.4 line_top=369.4 → y=476
    dt(p2,v('inviter_relation'),          177,476,379,7.5);
    // 邀请人职业: x0=151.4 line_top=388.3 → y=457
    dt(p2,v('inviter_job'),               155,457,401,7.5);
    // 邀请人国籍: x0=239.4 line_top=407.2 → y=438
    dt(p2,v('inviter_nationality'),       243,438,313,7.5);
    // 备注: x0=283.2 line_top=424.2 → y=421
    dt(p2,v('remarks'),                   287,421,269,7.5);

    // 是非问题 checkboxes — 是x=488 否x=523
    // Q1 y_top≈445 → pdflib=841.9-445-8=388.9
    dcb(p2,rv('q1')==='yes',506,389);dcb(p2,rv('q1')==='no',541,389);
    // Q2 y_top≈463 → 370.9
    dcb(p2,rv('q2')==='yes',506,371);dcb(p2,rv('q2')==='no',541,371);
    // Q3 y_top≈482 → 351.9
    dcb(p2,rv('q3')==='yes',506,352);dcb(p2,rv('q3')==='no',541,352);
    // Q4 two-line, checkbox at y_top≈514 → 319.9
    dcb(p2,rv('q4')==='yes',506,320);dcb(p2,rv('q4')==='no',541,320);
    // Q5 two-line, checkbox at y_top≈546 → 287.9
    dcb(p2,rv('q5')==='yes',506,288);dcb(p2,rv('q5')==='no',541,288);
    // Q6 y_top≈565 → 268.9
    dcb(p2,rv('q6')==='yes',506,269);dcb(p2,rv('q6')==='no',541,269);

    // 申请日期: bottom of page 2, label is at ~y_top=752 → pdflib y≈82
    // The date blank line is after the "申请日期__" text, x≈106
    dt(p2,fd(v('application_date')),      106, 82, 100, 8);

    const surname=v('surname_en')||'Applicant';
    const out=await doc.save();
    const url=URL.createObjectURL(new Blob([out],{type:'application/pdf'}));
    const a=document.createElement('a');
    a.href=url;a.download='Japan_Visa_'+surname.toUpperCase()+'_'+new Date().toISOString().slice(0,10)+'.pdf';
    document.body.appendChild(a);a.click();document.body.removeChild(a);URL.revokeObjectURL(url);
    document.getElementById('ok-msg').style.display='flex';
    document.getElementById('ok-msg').innerHTML='<span style="font-size:20px">🎉</span> PDF已生成！请打印后手写申请日期和签名，再提交至大使馆。';
  }catch(e){
    alert('生成PDF时出错：'+e.message);console.error(e);
  }
  document.getElementById('ov').classList.remove('show');
  document.getElementById('dl-btn').disabled=false;
}

function collectAll(){
  const data={};
  document.querySelectorAll('input[type=text],input[type=date],input[type=email],input[type=tel],textarea').forEach(el=>{if(el.id)data[el.id]=el.value;});
  document.querySelectorAll('input[type=radio]:checked').forEach(el=>{data['radio_'+el.name]=el.value;});
  return data;
}
function restoreAll(data){
  Object.entries(data).forEach(([key,val])=>{
    if(key.startsWith('radio_')){
      const el=document.querySelector('input[name="'+key.slice(6)+'"][value="'+val+'"]');
      if(el)el.checked=true;
    }else{const el=document.getElementById(key);if(el)el.value=val;}
  });
}
function saveData(){
  localStorage.setItem('japan_visa_form',JSON.stringify(collectAll()));
  const st=document.getElementById('save-status');
  st.textContent='✓ 已保存 '+new Date().toLocaleTimeString();
  setTimeout(()=>st.textContent='',3000);
}
function loadData(){
  const raw=localStorage.getItem('japan_visa_form');
  if(!raw){alert('没有找到已保存的数据');return;}
  try{restoreAll(JSON.parse(raw));document.getElementById('save-status').textContent='✓ 已加载';setTimeout(()=>document.getElementById('save-status').textContent='',3000);}
  catch(e){alert('加载失败：'+e.message);}
}
function clearData(){
  if(!confirm('确认清除所有已保存的数据？'))return;
  localStorage.removeItem('japan_visa_form');
  document.getElementById('save-status').textContent='已清除';
  setTimeout(()=>document.getElementById('save-status').textContent='',2000);
}
setInterval(saveData,60000);
</script>
