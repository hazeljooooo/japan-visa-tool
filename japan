<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>赴日签证申请表 · 填写工具</title>
<script>
(function(){
  var cdns=[
    'https://cdn.jsdelivr.net/npm/pdf-lib@1.17.1/dist/pdf-lib.min.js',
    'https://unpkg.com/pdf-lib@1.17.1/dist/pdf-lib.min.js'
  ];
  var fkCdns=[
    'https://cdn.jsdelivr.net/npm/@pdf-lib/fontkit@1.1.1/dist/fontkit.umd.min.js',
    'https://unpkg.com/@pdf-lib/fontkit@1.1.1/dist/fontkit.umd.min.js'
  ];
  function loadScript(cdns,idx,cb){
    if(idx>=cdns.length){console.error('All CDNs failed for',cdns[0]);return;}
    var s=document.createElement('script');s.src=cdns[idx];
    s.onload=cb; s.onerror=function(){loadScript(cdns,idx+1,cb);};
    document.head.appendChild(s);
  }
  loadScript(cdns,0,function(){loadScript(fkCdns,0,function(){console.log('pdf-lib+fontkit ready');});});
})();
</script>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'PingFang SC','Microsoft YaHei',sans-serif;background:#f0f4f8;color:#1a202c}
.hdr{background:linear-gradient(135deg,#bc0027,#8b0000);color:#fff;padding:18px 28px;display:flex;align-items:center;gap:14px;box-shadow:0 4px 12px rgba(188,0,39,.35)}
.jp-flag{font-size:32px;flex-shrink:0}
.hdr h1{font-size:18px;font-weight:700}.hdr p{font-size:12px;opacity:.85;margin-top:2px}
.container{max-width:860px;margin:0 auto;padding:18px 12px 60px}
.prog{background:#fff;border-radius:10px;padding:12px 18px;margin-bottom:14px;box-shadow:0 2px 6px rgba(0,0,0,.07);display:flex;align-items:center;gap:4px}
.dot{width:26px;height:26px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;cursor:pointer;flex-shrink:0;transition:all .2s}
.dot.active{background:#bc0027;color:#fff}.dot.done{background:#10b981;color:#fff}.dot.idle{background:#e2e8f0;color:#718096}
.ln{flex:1;height:2px;border-radius:2px}.ln.done{background:#10b981}.ln.idle{background:#e2e8f0}
.slabel{font-size:11px;color:#718096;margin-left:6px;font-weight:500}
.card{background:#fff;border-radius:12px;padding:20px;margin-bottom:12px;box-shadow:0 2px 6px rgba(0,0,0,.07);display:none}
.card.active{display:block}
.ctitle{font-size:14px;font-weight:700;color:#bc0027;padding-bottom:10px;margin-bottom:14px;border-bottom:2px solid #fff0f3;display:flex;align-items:center;gap:7px}
.grid{display:grid;gap:11px}.g2{grid-template-columns:1fr 1fr}.g3{grid-template-columns:1fr 1fr 1fr}.full{grid-column:1/-1}
.fg{display:flex;flex-direction:column;gap:4px}
label{font-size:12px;font-weight:600;color:#4a5568;display:flex;align-items:center;gap:3px}
.req{color:#e53e3e}
.hint{font-size:10px;color:#a0aec0;margin-top:1px}
input[type=text],input[type=date],input[type=email],input[type=tel],textarea{
  border:1.5px solid #e2e8f0;border-radius:7px;padding:7px 10px;font-size:13px;
  font-family:inherit;background:#fafafa;color:#1a202c;width:100%;
  transition:border-color .2s,box-shadow .2s}
input:focus,textarea:focus{outline:none;border-color:#bc0027;box-shadow:0 0 0 3px rgba(188,0,39,.1);background:#fff}
textarea{resize:vertical;min-height:60px}
.radios{display:flex;flex-wrap:wrap;gap:6px;margin-top:2px}
.ri{display:flex;align-items:center;gap:4px;background:#f7fafc;border:1.5px solid #e2e8f0;border-radius:7px;padding:5px 9px;cursor:pointer;font-size:12px;transition:all .15s}
.ri:hover{border-color:#bc0027;background:#fff0f3}
.ri input{accent-color:#bc0027;width:13px;height:13px}
.divider{font-size:12px;font-weight:700;color:#4a5568;padding:10px 0 6px;border-top:1px dashed #e2e8f0;grid-column:1/-1;margin-top:2px}
.nav{display:flex;justify-content:space-between;margin-top:18px;padding-top:14px;border-top:1px solid #f0f4f8}
.btn{padding:8px 18px;border-radius:8px;font-size:13px;font-weight:600;cursor:pointer;border:none;transition:all .2s;display:inline-flex;align-items:center;gap:5px}
.btn-p{background:#bc0027;color:#fff}.btn-p:hover{background:#8b0000}
.btn-s{background:#f7fafc;color:#4a5568;border:1.5px solid #e2e8f0}.btn-s:hover{background:#fff0f3;border-color:#bc0027;color:#bc0027}
.btn-dl{background:#bc0027;color:#fff;font-size:14px;padding:12px 26px;border-radius:9px}
.btn-dl:hover{background:#8b0000}.btn-dl:disabled{opacity:.5;cursor:not-allowed}
.sumbox{background:#f0fdf4;border:1.5px solid #86efac;border-radius:9px;padding:12px;margin-bottom:14px}
.sumbox h3{font-size:12px;color:#166534;font-weight:700;margin-bottom:8px}
.sumgrid{display:grid;grid-template-columns:1fr 1fr;gap:4px}
.sumrow{display:flex;gap:4px;font-size:11px}
.sumlbl{font-weight:600;color:#166534;min-width:90px;white-space:nowrap}
.sumval{color:#15803d;word-break:break-all}
.tip{background:#fffbeb;border:1.5px solid #fcd34d;border-radius:7px;padding:8px 11px;font-size:11px;color:#92400e;margin-bottom:12px}
.ok{background:#10b981;color:#fff;border-radius:8px;padding:12px 16px;margin-bottom:14px;display:none;align-items:center;gap:8px;font-weight:600;font-size:13px}
#ov{display:none;position:fixed;inset:0;background:rgba(0,0,0,.55);z-index:100;justify-content:center;align-items:center;flex-direction:column;gap:16px;color:#fff}
#ov.show{display:flex}
#ov-msg{font-size:14px;font-weight:600;max-width:300px;text-align:center}
.spin{width:44px;height:44px;border:4px solid rgba(255,255,255,.3);border-top-color:#fff;border-radius:50%;animation:spin .8s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}
.savebar{background:#fff;border-bottom:2px solid #fff0f3;padding:10px 28px;display:flex;align-items:center;gap:10px;flex-wrap:wrap;box-shadow:0 1px 4px rgba(0,0,0,.06)}
@media(max-width:580px){.g2,.g3{grid-template-columns:1fr}.sumgrid{grid-template-columns:1fr}}
</style>
</head>
<body>
<div class="hdr">
  <div class="jp-flag">🇯🇵</div>
  <div><h1>赴日签证申请表 · 填写工具</h1><p>根据日本驻华大使馆官方申请表 · 填写完成后一键生成PDF，直接打印提交</p></div>
</div>
<div class="savebar">
  <span style="font-size:13px;font-weight:600;color:#4a5568">💾 数据：</span>
  <button onclick="saveData()" style="padding:7px 16px;background:#bc0027;color:#fff;border:none;border-radius:7px;font-size:12px;font-weight:600;cursor:pointer">保存</button>
  <button onclick="loadData()" style="padding:7px 16px;background:#f7fafc;color:#4a5568;border:1.5px solid #e2e8f0;border-radius:7px;font-size:12px;font-weight:600;cursor:pointer">加载上次</button>
  <button onclick="clearData()" style="padding:7px 16px;background:#fff5f5;color:#c53030;border:1.5px solid #fed7d7;border-radius:7px;font-size:12px;font-weight:600;cursor:pointer">清除</button>
  <span id="save-status" style="font-size:11px;color:#10b981;font-weight:600"></span>
</div>
<div class="container">
<div class="prog">
  <div class="dot active" id="d1" onclick="go(1)">1</div><div class="ln idle" id="l1"></div>
  <div class="dot idle"   id="d2" onclick="go(2)">2</div><div class="ln idle" id="l2"></div>
  <div class="dot idle"   id="d3" onclick="go(3)">3</div><div class="ln idle" id="l3"></div>
  <div class="dot idle"   id="d4" onclick="go(4)">4</div><div class="ln idle" id="l4"></div>
  <div class="dot idle"   id="d5" onclick="go(5)">5</div>
  <span class="slabel" id="slbl">基本信息</span>
</div>

<!-- STEP 1 -->
<div class="card active" id="s1">
  <div class="ctitle">👤 基本信息</div>
  <div class="grid g2">
    <div class="fg">
      <label>姓（英文，按护照）<span class="req">*</span></label>
      <input id="surname_en" type="text" placeholder="如：ZHANG">
      <span class="hint">大写英文字母</span>
    </div>
    <div class="fg">
      <label>姓（中文）</label>
      <input id="surname_cn" type="text" placeholder="如：张">
    </div>
    <div class="fg">
      <label>名（英文，按护照）<span class="req">*</span></label>
      <input id="given_en" type="text" placeholder="如：SAN">
      <span class="hint">大写英文字母</span>
    </div>
    <div class="fg">
      <label>名（中文）</label>
      <input id="given_cn" type="text" placeholder="如：三">
    </div>
    <div class="fg">
      <label>曾用名（英文）</label>
      <input id="alias_en" type="text" placeholder="如有则填写，否则留空">
    </div>
    <div class="fg">
      <label>曾用名（中文）</label>
      <input id="alias_cn" type="text" placeholder="如有则填写，否则留空">
    </div>
    <div class="fg">
      <label>出生日期<span class="req">*</span></label>
      <input id="dob" type="date">
      <span class="hint">自动转为 日/月/年 格式</span>
    </div>
    <div class="fg">
      <label>出生地点（省 / 市）<span class="req">*</span></label>
      <div style="display:flex;gap:6px">
        <input id="birthplace_province" type="text" placeholder="如：北京市">
        <input id="birthplace_city" type="text" placeholder="如：朝阳区">
      </div>
    </div>
    <div class="fg full">
      <label>性别<span class="req">*</span></label>
      <div class="radios">
        <label class="ri"><input type="radio" name="sex" value="male"> 男</label>
        <label class="ri"><input type="radio" name="sex" value="female"> 女</label>
      </div>
    </div>
    <div class="fg full">
      <label>婚姻状况<span class="req">*</span></label>
      <div class="radios">
        <label class="ri"><input type="radio" name="marital" value="single"> 单身</label>
        <label class="ri"><input type="radio" name="marital" value="married"> 已婚</label>
        <label class="ri"><input type="radio" name="marital" value="divorced"> 离婚</label>
        <label class="ri"><input type="radio" name="marital" value="widowed"> 丧偶</label>
      </div>
    </div>
    <div class="fg">
      <label>国籍（或公民身份）<span class="req">*</span></label>
      <input id="nationality" type="text" placeholder="如：中国">
    </div>
    <div class="fg">
      <label>曾有的或另有的国籍</label>
      <input id="other_nationality" type="text" placeholder="如无则留空">
    </div>
    <div class="fg full">
      <label>身份证号码</label>
      <input id="id_number" type="text" placeholder="如：110101199001011234">
    </div>
    <div class="fg full">
      <label>申请日期<span class="req">*</span></label>
      <input id="application_date" type="date">
      <span class="hint">填写您提交申请的日期，将打印在PDF上</span>
    </div>
  </div>
  <div class="nav"><div></div><button class="btn btn-p" onclick="next()">下一步：护照信息 →</button></div>
</div>

<!-- STEP 2 -->
<div class="card" id="s2">
  <div class="ctitle">🛂 护照信息</div>
  <div class="grid g2">
    <div class="fg full">
      <label>护照类别<span class="req">*</span></label>
      <div class="radios">
        <label class="ri"><input type="radio" name="passtype" value="ordinary" checked> 普通</label>
        <label class="ri"><input type="radio" name="passtype" value="diplomatic"> 外交</label>
        <label class="ri"><input type="radio" name="passtype" value="official"> 公务</label>
        <label class="ri"><input type="radio" name="passtype" value="other"> 其它</label>
      </div>
    </div>
    <div class="fg">
      <label>护照号码<span class="req">*</span></label>
      <input id="passport_num" type="text" placeholder="如：E98236743">
    </div>
    <div class="fg">
      <label>签发地点<span class="req">*</span></label>
      <input id="issue_place" type="text" placeholder="如：北京">
    </div>
    <div class="fg">
      <label>签发日期<span class="req">*</span></label>
      <input id="issue_date" type="date">
      <span class="hint">自动转为 日/月/年 格式</span>
    </div>
    <div class="fg">
      <label>有效日期<span class="req">*</span></label>
      <input id="expiry_date" type="date">
      <span class="hint">自动转为 日/月/年 格式</span>
    </div>
    <div class="fg full">
      <label>签发机关</label>
      <input id="issue_authority" type="text" value="中华人民共和国国家移民管理局" placeholder="如：北京市公安局出入境管理局">
    </div>
    <div class="fg full">
      <label>在留资格认定证明书编号（如有）</label>
      <input id="coe_number" type="text" placeholder="如无则留空">
    </div>
  </div>
  <div class="nav">
    <button class="btn btn-s" onclick="prev()">← 上一步</button>
    <button class="btn btn-p" onclick="next()">下一步：行程信息 →</button>
  </div>
</div>

<!-- STEP 3 -->
<div class="card" id="s3">
  <div class="ctitle">✈️ 行程信息</div>
  <div class="grid g2">
    <div class="fg full">
      <label>居住身份 / 赴日目的<span class="req">*</span></label>
      <input id="purpose" type="text" placeholder="如：旅游、商务、探亲、留学">
    </div>
    <div class="fg">
      <label>预定抵达日期<span class="req">*</span></label>
      <input id="arrival_date" type="date">
      <span class="hint">自动转为 日/月/年 格式</span>
    </div>
    <div class="fg">
      <label>预定离开日期<span class="req">*</span></label>
      <input id="departure_date" type="date">
      <span class="hint">自动转为 日/月/年 格式</span>
    </div>
    <div class="fg">
      <label>预定逗留期间（天数）</label>
      <input id="stay_days" type="text" placeholder="如：14天">
    </div>
    <div class="fg">
      <label>入境口岸</label>
      <input id="entry_port" type="text" placeholder="如：成田机场">
    </div>
    <div class="fg full">
      <label>船舶或航空公司名称</label>
      <input id="carrier" type="text" placeholder="如：全日空 NH812">
    </div>
    <div class="divider">📍 在日住址</div>
    <div class="fg">
      <label>酒店名称或友人姓名<span class="req">*</span></label>
      <input id="hotel_name" type="text" placeholder="如：东京大仓饭店 / 山田太郎">
    </div>
    <div class="fg">
      <label>电话</label>
      <input id="hotel_phone" type="text" placeholder="如：+81-3-XXXX-XXXX">
    </div>
    <div class="fg full">
      <label>在日详细地址</label>
      <input id="hotel_address" type="text" placeholder="如：东京都港区虎之门2-10-1">
    </div>
    <div class="fg full">
      <label>上次赴日日期及停留时间</label>
      <input id="last_visit" type="text" placeholder="如：2022年3月15日，停留10天（或：无）">
    </div>
  </div>
  <div class="nav">
    <button class="btn btn-s" onclick="prev()">← 上一步</button>
    <button class="btn btn-p" onclick="next()">下一步：联系方式 →</button>
  </div>
</div>

<!-- STEP 4 -->
<div class="card" id="s4">
  <div class="ctitle">📋 联系方式 · 工作单位 · 担保人 · 邀请人</div>
  <div class="grid g2">
    <div class="divider">🏠 家庭地址</div>
    <div class="fg full">
      <label>家庭详细地址<span class="req">*</span></label>
      <input id="home_address" type="text" placeholder="如：北京市朝阳区XX路XX号XX室">
    </div>
    <div class="fg">
      <label>电话<span class="req">*</span></label>
      <input id="home_phone" type="tel" placeholder="如：010-12345678">
    </div>
    <div class="fg">
      <label>手机<span class="req">*</span></label>
      <input id="home_mobile" type="tel" placeholder="如：138-0000-0000">
    </div>
    <div class="fg full">
      <label>电子邮件</label>
      <input id="home_email" type="email" placeholder="如：zhangsan@163.com">
    </div>
    <div class="divider">🏢 工作单位名称及地址</div>
    <div class="fg">
      <label>单位名称<span class="req">*</span></label>
      <input id="employer_name" type="text" placeholder="如：北京XX科技有限公司">
    </div>
    <div class="fg">
      <label>单位电话</label>
      <input id="employer_phone" type="tel" placeholder="如：010-87654321">
    </div>
    <div class="fg full">
      <label>单位地址</label>
      <input id="employer_address" type="text" placeholder="如：北京市海淀区中关村大街XX号">
    </div>
    <div class="fg full">
      <label>目前的职位<span class="req">*</span></label>
      <input id="job_title" type="text" placeholder="如：软件工程师、教师、销售经理">
    </div>
    <div class="fg full">
      <label>配偶职业（未成年人填父母职业）</label>
      <input id="spouse_occupation" type="text" placeholder="如：教师（选填）">
    </div>
    <div class="divider">🇯🇵 在日担保人（姓名英文请按护照填写）</div>
    <div class="fg">
      <label>担保人姓名（英文）</label>
      <input id="guarantor_name_en" type="text" placeholder="如：YAMADA TARO">
    </div>
    <div class="fg">
      <label>担保人电话</label>
      <input id="guarantor_phone" type="tel" placeholder="如：+81-3-XXXX-XXXX">
    </div>
    <div class="fg full">
      <label>担保人地址</label>
      <input id="guarantor_address" type="text" placeholder="如：东京都新宿区西新宿1-1-1">
    </div>
    <div class="fg">
      <label>担保人出生日期</label>
      <input id="guarantor_dob" type="date">
    </div>
    <div class="fg">
      <label>与申请人的关系</label>
      <input id="guarantor_relation" type="text" placeholder="如：朋友、雇主、亲属">
    </div>
    <div class="fg">
      <label>担保人性别</label>
      <div class="radios">
        <label class="ri"><input type="radio" name="guarantor_sex" value="male"> 男</label>
        <label class="ri"><input type="radio" name="guarantor_sex" value="female"> 女</label>
      </div>
    </div>
    <div class="fg">
      <label>担保人职业和职务</label>
      <input id="guarantor_job" type="text" placeholder="如：公司职员">
    </div>
    <div class="fg full">
      <label>担保人国籍及签证种类</label>
      <input id="guarantor_nationality" type="text" placeholder="如：日本国籍、永住者">
    </div>
    <div class="divider">📨 在日邀请人（与担保人相同则填"同上"）</div>
    <div class="fg">
      <label>邀请人姓名</label>
      <input id="inviter_name" type="text" placeholder="如：同上 / 山田花子">
    </div>
    <div class="fg">
      <label>邀请人电话</label>
      <input id="inviter_phone" type="tel" placeholder="如：同上 / +81-90-XXXX-XXXX">
    </div>
    <div class="fg full">
      <label>邀请人地址</label>
      <input id="inviter_address" type="text" placeholder="如：同上 / 大阪市中央区XX1-1-1">
    </div>
    <div class="fg">
      <label>邀请人出生日期</label>
      <input id="inviter_dob" type="date">
    </div>
    <div class="fg">
      <label>与申请人的关系</label>
      <input id="inviter_relation" type="text" placeholder="如：朋友、亲属">
    </div>
    <div class="fg">
      <label>邀请人性别</label>
      <div class="radios">
        <label class="ri"><input type="radio" name="inviter_sex" value="male"> 男</label>
        <label class="ri"><input type="radio" name="inviter_sex" value="female"> 女</label>
      </div>
    </div>
    <div class="fg">
      <label>邀请人职业和职务</label>
      <input id="inviter_job" type="text" placeholder="如：公司职员">
    </div>
    <div class="fg full">
      <label>邀请人国籍及签证种类</label>
      <input id="inviter_nationality" type="text" placeholder="如：日本国籍">
    </div>
    <div class="divider">⚠️ 申报事项</div>
    <div class="fg full">
      <label>备注（选填）</label>
      <textarea id="remarks" placeholder="如有需特殊说明的事项请在此填写，否则留空"></textarea>
    </div>
    <div class="fg full"><label style="color:#c53030;font-weight:700">是否曾在任何国家被判决有罪？<span class="req">*</span></label>
